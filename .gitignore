# MTHO-CORE (Genesis Protocol)
# Exclusions

# Environments & Secrets
.env
.secrets.mth
openclaw_admin_config.json
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# IDE & Meta
.vscode/
.idea/
.cursor/
!.cursor/rules/
!.cursor/skills/
!.cursorrules

# System Artifacts
terminals/
agent-transcripts/
*.log
*.tmp
*.bak
temp_*.py
test_webhook.sh

# Dependencies
node_modules/
dist/
build/

# OS Specific
.DS_Store
Thumbs.db

# Local Data Directories
media/
data/

# Backups (enthalten Secrets, Keys, DB-Dumps)
backups/

# go2rtc / FFmpeg binaries (zu groß für GitHub, siehe driver/README)
driver/go2rtc_win64/

# ISO images (zu gross fuer GitHub, lokal behalten)
*.iso

# ENV Templates mit echten Werten
CLEAN_ENV_TEMPLATE.txt
