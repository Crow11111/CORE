[Unit]
Description=OMEGA CORE - Dreadnought IDE Membrane (Local Enforcer)
After=network.target

[Service]
Type=simple
User=mth
WorkingDirectory=/OMEGA_CORE
Environment="PYTHONPATH=/OMEGA_CORE"
ExecStart=/usr/bin/python src/daemons/dread_membrane_daemon.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
